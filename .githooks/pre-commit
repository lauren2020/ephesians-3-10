#!/bin/sh
#
# pre-commit hook: rebuild the site whenever the manuscript changes.
#
# Tracked in the repo under .githooks/ and activated with:
#     git config core.hooksPath .githooks
# (run once per clone — see .githooks/setup or the README note).
#
# Works on macOS, Linux, and Windows. Git for Windows runs this script with
# its bundled bash, and VS Code's Git integration invokes the same git binary,
# so commits made from the VS Code Source Control panel run this hook too.

# Only act when staged changes touch the manuscript/ directory.
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^manuscript/'; then
    echo "pre-commit: manuscript/ changed — rebuilding site/ ..."

    # Find a Python interpreter. On Windows, python/python3 may be Microsoft
    # Store aliases that exist on PATH but are not real interpreters, so verify
    # each candidate before using it.
    PY=
    if command -v py >/dev/null 2>&1 && py -3 --version >/dev/null 2>&1; then
        PY="py -3"
    else
        for EXE in "$LOCALAPPDATA"/Programs/Python/Python*/python.exe "$HOME"/AppData/Local/Programs/Python/Python*/python.exe; do
            if [ -x "$EXE" ] && "$EXE" --version >/dev/null 2>&1; then
                PY="$EXE"
                break
            fi
        done
    fi

    if [ -n "$PY" ]; then
        :
    elif command -v python3 >/dev/null 2>&1 && python3 --version >/dev/null 2>&1; then
        PY=python3
    elif command -v python >/dev/null 2>&1 && python --version >/dev/null 2>&1; then
        PY=python
    else
        echo "pre-commit ERROR: no working Python 3 interpreter found." >&2
        echo "  Install Python 3 and try again, or commit with --no-verify to skip." >&2
        exit 1
    fi

    # Run the build from the repo root regardless of where the commit was launched.
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if ! (cd "$REPO_ROOT" && PYTHONDONTWRITEBYTECODE=1 $PY build_site.py); then
        echo "pre-commit ERROR: build_site.py failed — commit aborted." >&2
        echo "  Fix the build (e.g. 'pip install pythonbible pythonbible-kjv')," >&2
        echo "  or commit with --no-verify to skip this hook." >&2
        exit 1
    fi

    # Include the freshly generated site/ in this commit so text and build stay in sync.
    (cd "$REPO_ROOT" && git add site)
    echo "pre-commit: site/ rebuilt and staged."
fi

exit 0
